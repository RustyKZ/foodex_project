#Dev or Prod mode
API_SERVICE_DEV_MODE=True

#JWT params
API_SERVICE_JWT_SECRET=JWT_SecretKey
API_SERVICE_JWT_ALGORITHM=HS256
API_SERVICE_JWT_EXP_DELTA_SECONDS=2400
API_SERVICE_JWT_REFRESH_PERIOD_SECONDS=600

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redis_password


#Database params
API_SERVICE_DB_NAME=db_name
API_SERVICE_DB_USER=bd_username
API_SERVICE_DB_PASSWORD=db_password
API_SERVICE_DB_HOST=postgres
API_SERVICE_DB_PORT=5432


#CORS params
API_SERVICE_CORS_ALLOW_ORIGINS=*
API_SERVICE_WS_CORS_ALLOW_ORIGINS=https://tma.foodexapp.top


#RabbitMQ params
API_SERVICE_RABBIT_USERNAME=rabbit_username
API_SERVICE_RABBIT_PASSWORD=rabbit_password
API_SERVICE_RABBIT_HOST=rabbitmq



